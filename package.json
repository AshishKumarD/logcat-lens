{
	"name": "logcat-lens",
	"displayName": "Logcat Lens",
	"icon": "res/icon.png",
	"description": "A powerful Android Logcat viewer for VS Code — stream, filter, and search logs without leaving your editor.",
	"version": "2.1.0",
	"publisher": "AshishKumarD",
	"author": "Ashish Kumar",
	"engines": {
		"vscode": "^1.90.0"
	},
	"categories": [
		"Debuggers",
		"Other"
	],
	"keywords": [
		"android",
		"logcat",
		"adb",
		"debug",
		"logs",
		"log viewer",
		"android studio"
	],
	"repository": {
		"type": "git",
		"url": "https://github.com/AshishKumarD/logcat-lens"
	},
	"galleryBanner": {
		"color": "#1a1a2e",
		"theme": "dark"
	},
	"activationEvents": [],
	"main": "./src/backend/extension.js",
	"contributes": {
		"viewsContainers": {
			"panel": [
				{
					"id": "logcat-lens-container",
					"title": "Logcat Lens",
					"icon": ""
				}
			]
		},
		"views": {
			"logcat-lens-container": [
				{
					"id": "logcat-lens-main-view",
					"type": "webview",
					"name": "",
					"contextualTitle": "Logcat Lens",
					"visibility": "visible",
					"icon": ""
				}
			]
		},
		"configuration": {
			"title": "Logcat Lens",
			"properties": {
				"logcatLens.adbPath": {
					"type": "string",
					"default": "",
					"description": "Absolute path to the adb binary. Leave empty to auto-detect from ANDROID_HOME or common install locations."
				},
				"logcatLens.tagGroups": {
					"type": "object",
					"default": {},
					"description": "Saved tag groups. Keys are group names, values are arrays of tag strings."
				}
			}
		}
	},
	"scripts": {
		"lint": "eslint ."
	},
	"devDependencies": {
		"@types/vscode": "^1.90.0",
		"@types/node": "20.x",
		"eslint": "^8.57.0"
	}
}
